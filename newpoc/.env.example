# ── Browserbase ──────────────────────────────────────────────────────────────
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Persistent session ID — refresh periodically via the Clerk flow
BROWSERBASE_SESSION_ID=

# ── LLM Keys (Stagehand + Lab A/B testing) ───────────────────────────────────
GOOGLE_API_KEY=          # Gemini (primary agent model via Stagehand)
ANTHROPIC_API_KEY=       # Claude direct API
OPENAI_API_KEY=          # OpenAI direct API
OPENROUTER_API_KEY=      # OpenRouter — single key for all Lab A/B models (gemini, gpt, claude)

# ── eBay Credentials ─────────────────────────────────────────────────────────
EBAY_USERNAME=
EBAY_PASSWORD=           # Never logged or sent to LLM — Stagehand variables{} only

# ── Conductor Config ─────────────────────────────────────────────────────────
DAILY_SPEND_LIMIT=500.00         # Budget circuit breaker ($)
AGENT_BUDGET=150.00              # Autonomous authority ceiling — above this, notify first
TAX_RATE=0.09                    # Estimated sales tax rate
PRICE_TRIGGER_DELTA=100.00       # Min $ undervalue vs sanitized_avg to trigger agent

# ── Shipping Address (used by agent to fill guest checkout form) ─────────────
SHIPPING_FIRST_NAME=
SHIPPING_LAST_NAME=
SHIPPING_ADDRESS=
SHIPPING_CITY=
SHIPPING_STATE=            # 2-letter US state code, e.g. NY
SHIPPING_ZIP=
SHIPPING_PHONE=

# ── Reddit Sentiment ─────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cardhero-watchman/1.0

# ── Web Push Notifications ───────────────────────────────────────────────────
VAPID_PRIVATE_KEY=          # base64url-encoded VAPID private key (run Task 1 Step 3 to generate)
VAPID_PUBLIC_KEY=           # base64url-encoded VAPID public key (application server key)
