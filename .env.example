# ============================================================
# CardHero Last-Mile Engine — Environment Variables
# Copy to .env and fill in real values before running.
# ============================================================

# --- Browserbase (required for agent) ---
# Get from https://browserbase.com/dashboard
BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxx
BROWSERBASE_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# --- LLM Provider for Stagehand v3 (use ONE) ---
# Stagehand reads the key automatically by provider name prefix in the model string.
# Recommended: Google Gemini 2.5 Flash (fast, accurate, cost-effective)
GOOGLE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- eBay credentials ---
# Used ONLY by Stagehand's variables{} masking — these values NEVER reach the LLM.
# The agent passes them as variables: { username: process.env.EBAY_USERNAME }
# and Stagehand substitutes them directly into DOM interactions.
EBAY_USERNAME=your_ebay_email@example.com
EBAY_PASSWORD=your_ebay_password

# --- Conductor (backend FastAPI server) ---
CONDUCTOR_URL=http://localhost:8000
DAILY_SPEND_LIMIT=600.00
TAX_RATE=0.08

# --- Watchman ---
# How often (seconds) the watchman polls eBay for each WantList item
POLL_INTERVAL=300
